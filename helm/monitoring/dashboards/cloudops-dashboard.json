{
  "title": "CloudOps Incident Manager",
  "uid": "cloudops-main",
  "timezone": "browser",
  "panels": [
    {
      "title": "API Latency p95",
      "type": "graph",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{namespace='cloudops'}[5m])) by (le, service))",
          "legendFormat": "p95 - {{service}}"
        }
      ]
    },
    {
      "title": "API Latency p99",
      "type": "graph",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{namespace='cloudops'}[5m])) by (le, service))",
          "legendFormat": "p99 - {{service}}"
        }
      ]
    },
    {
      "title": "SLA Breach Rate",
      "type": "stat",
      "gridPos": { "x": 0, "y": 8, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(increase(cloudops_sla_breach_total[1h]))",
          "legendFormat": "Breaches/heure"
        }
      ]
    },
    {
      "title": "Incidents ouverts",
      "type": "stat",
      "gridPos": { "x": 6, "y": 8, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "cloudops_incidents_open_total",
          "legendFormat": "Incidents OPEN"
        }
      ]
    },
    {
      "title": "Kafka Consumer Lag",
      "type": "graph",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(kafka_consumer_group_lag) by (group, topic)",
          "legendFormat": "{{group}} - {{topic}}"
        }
      ]
    },
    {
      "title": "JVM Heap Usage",
      "type": "graph",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(jvm_memory_used_bytes{area='heap', namespace='cloudops'}) by (service)",
          "legendFormat": "Heap - {{service}}"
        }
      ]
    },
    {
      "title": "Pods Running",
      "type": "stat",
      "gridPos": { "x": 12, "y": 16, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "count(kube_pod_status_phase{namespace='cloudops', phase='Running'})",
          "legendFormat": "Pods actifs"
        }
      ]
    }
  ],
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" }
}